{
  "expo": {
    "name": "VocaQuest",
    "slug": "vocaquest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "vocaquest",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.realsnoopso.vocaquest",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.realsnoopso.vocaquest"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "./plugins/withSwiftConcurrency"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aeae65d7-d717-407c-89b0-d7c5a2cc5494"
      }
    },
    "owner": "realsnoopsoso",
    "updates": {
      "url": "https://u.expo.dev/aeae65d7-d717-407c-89b0-d7c5a2cc5494"
    },
    "runtimeVersion": "1.0.0"
  }
}
